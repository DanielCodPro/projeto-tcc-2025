APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE= /* nome do banco de dados (ex: salgadaria_db) */ 
DB_USERNAME= /* nome do usuário do banco de dados(ex: root) */
DB_PASSWORD= /* senha do banco de dados (ex: 1234) */

GOOGLE_CLIENT_ID= /* ID do cliente OAuth 2.0 do Google */
GOOGLE_CLIENT_SECRET= /* Segredo do cliente OAuth 2.0 do Google */
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

MERCADO_PAGO_ACCESS_TOKEN= /* Token de acesso do Mercado Pago */

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN= /* domínio da sessão, se for para testes locais utilize localhost, caso hospeadado na nuvem (ex: meusite.com.br) */

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME= /* seu e-mail (ex: nome@gmail.com) */
MAIL_PASSWORD= /* sua senha ou senha de app (ex: 1234 ou abcd-efgh-ijkl-mnop) */
MAIL_ENCRYPTION=null /* tls ou ssl, caso utilize o mailhog deixe como null */
MAIL_FROM_ADDRESS="hello@example.com" /* e-mail que aparecerá como remetente */
MAIL_FROM_NAME="${APP_NAME}" /* nome que aparecerá como remetente */

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"